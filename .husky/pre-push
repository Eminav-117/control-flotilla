#!/usr/bin/env sh
# Pre-push — corre verificación completa local mientras GitHub Actions
# está pausado por billing. Replica el pipeline de .github/workflows/ci.yml.
#
# Para saltar en emergencia (NO recomendado):
#   git push --no-verify
#
# Remover cuando billing se resuelva y workflow_dispatch vuelva a push auto.

set -e

echo "→ [1/4] Typecheck (tsc --noEmit)..."
npm run typecheck

echo "→ [2/4] Lint (eslint)..."
npm run lint

echo "→ [3/4] Unit tests (vitest)..."
npm run test:run

echo "→ [4/4] E2E tests (playwright)..."
npm run test:e2e

echo "✓ Pre-push OK — push procede"
